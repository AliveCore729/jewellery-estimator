// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

enum Role {
  ADMIN
  STAFF
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         Role      @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  estimates    Estimate[]
  activityLogs ActivityLog[]
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates Estimate[]

  @@index([phone])
  @@index([name])
}

// ============================================
// MATERIALS & RATES
// ============================================

enum MaterialCategory {
  GOLD
  SILVER
  PLATINUM
  DIAMOND
  GEMSTONE
  OTHER
}

enum WeightUnit {
  GRAM
  TOLA
  CARAT
  PIECE
}

enum RateSource {
  API
  MANUAL
}

model Material {
  id          String           @id @default(cuid())
  name        String
  category    MaterialCategory
  purity      String?
  defaultUnit WeightUnit       @default(GRAM)
  hsnCode     String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())

  rates            MaterialRate[]
  variantMaterials VariantMaterial[]
}

model MaterialRate {
  id            String     @id @default(cuid())
  materialId    String
  ratePerUnit   Decimal    @db.Decimal(12, 2)
  unit          WeightUnit
  source        RateSource @default(MANUAL)
  effectiveDate DateTime   @default(now())
  createdAt     DateTime   @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId, effectiveDate(sort: Desc)])
}

// ============================================
// CATEGORIES
// ============================================

enum ChargeType {
  FIXED
  PERCENTAGE
  PER_GRAM
}

model Category {
  id                 String      @id @default(cuid())
  name               String
  defaultWastagePct  Decimal     @default(0) @db.Decimal(5, 2)
  defaultMakingType  ChargeType?
  defaultMakingValue Decimal?    @db.Decimal(10, 2)
  sortOrder          Int         @default(0)
  isActive           Boolean     @default(true)

  estimates Estimate[]
}

// ============================================
// ESTIMATES (Core of the App)
// ============================================

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  INVOICED
}

model Estimate {
  id                 String         @id @default(cuid())
  estimateNumber     String         @unique
  customerId         String
  categoryId         String?
  productName        String
  productDescription String?
  status             EstimateStatus @default(DRAFT)
  rateLockDate       DateTime       @default(now())
  validUntil         DateTime?
  version            Int            @default(1)
  parentEstimateId   String?
  notes              String?
  createdById        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  customer       Customer          @relation(fields: [customerId], references: [id])
  category       Category?         @relation(fields: [categoryId], references: [id])
  createdBy      User              @relation(fields: [createdById], references: [id])
  parentEstimate Estimate?         @relation("EstimateVersions", fields: [parentEstimateId], references: [id])
  childEstimates Estimate[]        @relation("EstimateVersions")
  variants       EstimateVariant[]
  shares         EstimateShare[]

  @@index([customerId])
  @@index([status])
  @@index([estimateNumber])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// ESTIMATE VARIANTS (Option A, B, C...)
// ============================================

model EstimateVariant {
  id                     String  @id @default(cuid())
  estimateId             String
  variantLabel           String
  sortOrder              Int     @default(0)
  totalMaterialCost      Decimal @default(0) @db.Decimal(12, 2)
  totalMakingCharges     Decimal @default(0) @db.Decimal(12, 2)
  totalAdditionalCharges Decimal @default(0) @db.Decimal(12, 2)
  subtotal               Decimal @default(0) @db.Decimal(12, 2)
  cgstAmount             Decimal @default(0) @db.Decimal(12, 2)
  sgstAmount             Decimal @default(0) @db.Decimal(12, 2)
  taxAmount              Decimal @default(0) @db.Decimal(12, 2)
  oldGoldDeduction       Decimal @default(0) @db.Decimal(12, 2)
  grandTotal             Decimal @default(0) @db.Decimal(12, 2)
  isRecommended          Boolean @default(false)

  estimate       Estimate          @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  materials      VariantMaterial[]
  charges        VariantCharge[]
  taxes          VariantTax[]
  oldGoldEntries OldGoldEntry[]
}

// ============================================
// VARIANT LINE ITEMS
// ============================================

model VariantMaterial {
  id            String     @id @default(cuid())
  variantId     String
  materialId    String
  weight        Decimal    @db.Decimal(10, 3)
  unit          WeightUnit
  ratePerUnit   Decimal    @db.Decimal(12, 2)
  wastagePct    Decimal    @default(0) @db.Decimal(5, 2)
  wastageWeight Decimal    @default(0) @db.Decimal(10, 3)
  totalWeight   Decimal    @db.Decimal(10, 3)
  huid          String?
  lineTotal     Decimal    @db.Decimal(12, 2)

  variant  EstimateVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  material Material        @relation(fields: [materialId], references: [id])
}

model VariantCharge {
  id               String     @id @default(cuid())
  variantId        String
  chargeName       String
  chargeType       ChargeType
  chargeValue      Decimal    @db.Decimal(10, 2)
  calculatedAmount Decimal    @db.Decimal(12, 2)

  variant EstimateVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model VariantTax {
  id        String  @id @default(cuid())
  variantId String
  taxName   String
  taxPct    Decimal @db.Decimal(5, 2)
  taxAmount Decimal @db.Decimal(12, 2)
  hsnCode   String?

  variant EstimateVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ============================================
// OLD GOLD EXCHANGE
// ============================================

model OldGoldEntry {
  id              String  @id @default(cuid())
  variantId       String
  itemDescription String?
  grossWeight     Decimal @db.Decimal(10, 3)
  purity          String?
  netWeight       Decimal @db.Decimal(10, 3)
  ratePerUnit     Decimal @db.Decimal(12, 2)
  deductionAmount Decimal @db.Decimal(12, 2)

  variant EstimateVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ============================================
// SHARING & TRACKING
// ============================================

enum ShareChannel {
  WHATSAPP
  EMAIL
  LINK
}

model EstimateShare {
  id         String       @id @default(cuid())
  estimateId String
  channel    ShareChannel
  recipient  String?
  shareToken String       @unique @default(cuid())
  sharedAt   DateTime     @default(now())
  viewedAt   DateTime?

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([shareToken])
}

// ============================================
// ACTIVITY / AUDIT LOG
// ============================================

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
}

// ============================================
// SHOP SETTINGS (Single row for single shop)
// ============================================

model ShopSettings {
  id                   String     @id @default(cuid())
  shopName             String
  address              String?
  phone                String?
  email                String?
  gstin                String?
  logoUrl              String?
  defaultTaxPct        Decimal    @default(3.0) @db.Decimal(5, 2)
  cgstPct              Decimal    @default(1.5) @db.Decimal(5, 2)
  sgstPct              Decimal    @default(1.5) @db.Decimal(5, 2)
  estimatePrefix       String     @default("EST")
  estimateValidityDays Int        @default(3)
  defaultWeightUnit    WeightUnit @default(GRAM)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}